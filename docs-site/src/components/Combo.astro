---
// Combo — an outlined "pairs well with" note. Teaches which commands / skills / flows combine, so a
// reader learns the next useful thing without hunting. Content (usually links) goes in the slot.
// Usage in MDX:
//   <Combo>[`cckit copilot`](/copilot/) then [`cckit watch`](/copilot/)</Combo>
const { label = 'Combo with' } = Astro.props;
---
<aside class="cckit-combo not-content">
  <span class="cckit-combo__label">{label}</span>
  <span class="cckit-combo__body"><slot /></span>
</aside>
