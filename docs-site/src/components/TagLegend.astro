---
// TagLegend — the key to the activation tags, GROUPED by what kind of thing the tag marks: how you
// trigger it, what runs on its own, and the concepts. Rendered as a TABLE so the pills and their
// meanings line up in columns. Drop it once on a "how to read" page.
import Tag, { TAGS } from './Tag.astro';
const groups = [
  { title: 'You trigger it', kinds: ['conversational', 'command', 'skill'] },
  { title: 'It runs on its own', kinds: ['hook'] },
  { title: 'Concepts', kinds: ['flow', 'agent', 'concept'] },
];
---
<table class="cckit-legend-table">
  <thead>
    <tr><th>Tag</th><th>What it means</th></tr>
  </thead>
  {groups.map((g) => (
    <tbody>
      <tr class="cckit-legend-table__group"><th colspan="2" scope="colgroup">{g.title}</th></tr>
      {g.kinds.map((kind) => (
        <tr>
          <td><Tag kind={kind} /></td>
          <td>{TAGS[kind].desc}</td>
        </tr>
      ))}
    </tbody>
  ))}
</table>
